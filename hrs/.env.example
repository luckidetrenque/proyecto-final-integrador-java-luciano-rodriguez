# Base de datos
DB_PASSWORD=cambiar_por_password_seguro

# Servidor
SERVER_PORT=8080

# Emails permitidos para registro (separados por coma)
WHITELIST_EMAILS=email1@gmail.com,email2@gmail.com

# CORS - dominio del frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173