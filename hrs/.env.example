# ==========================================
# COPIAR ESTE ARCHIVO A .env Y COMPLETAR
# ==========================================

SPRING_PROFILE=local

# Base de datos PostgreSQL (Neon)
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Servidor
SERVER_PORT=8080

# Emails permitidos para registro (separados por coma)
WHITELIST_EMAILS=

# CORS - dominio del frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Usuarios iniciales (DataInitializer - solo se crean si la BD está vacía)
APP_ADMIN_EMAIL=
APP_ADMIN_PASSWORD=
APP_COORDINATOR_EMAILS=
APP_COORDINATOR_PASSWORD=